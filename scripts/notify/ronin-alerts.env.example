# ronin-alerts.env.example
#
# Copy this to ~/.config/ronin-alerts.env (NEVER commit the real file — it lives
# outside the repo root and is not tracked by git). The file is sourced by
# scripts/notify/ntfy-send.sh when $NTFY_TOPIC is not already set in the environment.
#
# Setup:
#   cp scripts/notify/ronin-alerts.env.example ~/.config/ronin-alerts.env
#   # then edit ~/.config/ronin-alerts.env with your real topic name
#   chmod 600 ~/.config/ronin-alerts.env
#
# Topic naming: pick a random, hard-to-guess string. Public ntfy.sh topics are
# effectively shared secrets — anyone who knows the topic name can subscribe.
# Prefer a format like: ronin-<your-name>-<random-hex>
# Example: ronin-brian-a3f7c2e9
#
# For private push (no guessing risk), self-host ntfy and set upstream-base-url
# in its server.yml so iOS APNs relay still works. See runbook for details.
#

NTFY_TOPIC=ronin-REPLACE-ME-<random>

# Optional: override default thresholds for local monitors
# DOCKER_CACHE_THRESHOLD_GB=30
# DISK_FREE_MIN_GB=15
