{
  "name": "ronin-dojo-app",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "@ronin-dojo/web",
    "@swc/core",
    "@parcel/watcher",
    "prisma",
    "@prisma/engines",
    "esbuild",
    "sharp"
  ],
  "scripts": {
    "dev": "bun run --filter @ronin-dojo/web dev",
    "build": "bun run --filter @ronin-dojo/web build",
    "lint": "bun run --filter '*' lint",
    "wiki:lint": "bun run scripts/wiki-lint.ts",
    "markdown:lint:architecture": "npx markdownlint-cli2 \"docs/architecture/**/*.md\" \"docs/architecture/*.md\"",
    "markdown:fix:architecture": "bun run scripts/fix-architecture-markdownlint.ts",
    "docs:nav": "python3 scripts/generate-docs-nav.py",
    "graphify:viz": "GRAPHIFY_VIZ_NODE_LIMIT=10000 graphify export --format html --out apps/web/public/graphify.html",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:e2e": "bun run --filter @ronin-dojo/web test:e2e",
    "audit:fallow": "fallow audit --changed-since HEAD",
    "audit:fallow:all": "fallow audit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "fallow": "^2.91.0"
  }
}
