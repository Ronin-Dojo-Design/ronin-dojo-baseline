# Baseline — its OWN database (ADR 0038: one database per product).
#
# Each product owns its own DATABASE_URL; there is no shared DB and no
# cross-product foreign keys. Baseline does NOT read BBL's lineage DB.
# Copy this file to `.env` (gitignored) for local dev.
#
# Local dev = Postgres.app. Omitting the user lets libpq default to your macOS
# username (trust auth). Set an explicit user if yours differs.
DATABASE_URL="postgresql://localhost:5432/baseline_dev"
