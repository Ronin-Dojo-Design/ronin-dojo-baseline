# FS-0031 — local e2e env overlay. The REAL `.env.e2e` is gitignored (it carries real secrets).
#
# Create it by copying your working `.env` and overriding ONLY the database URLs to the small,
# seeded e2e DB (so heavy admin pages like /app/blog render locally instead of timing out on the
# full ronindojo_prodsnap). Everything else — BETTER_AUTH_SECRET, BETTER_AUTH_URL,
# NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_SITE_EMAIL, S3_*, STRIPE_*, … — must stay present, because
# `bun --env-file=.env.e2e` REPLACES the default `.env` load (t3-env validates the full set).
#
#   cd apps/web
#   cp .env .env.e2e
#   # then edit .env.e2e so both point at ronindojo_e2e (local user = the one in your .env):
#   #   DATABASE_URL="postgresql://<localuser>@localhost:5432/ronindojo_e2e"
#   #   DIRECT_URL="postgresql://<localuser>@localhost:5432/ronindojo_e2e"
#   bun run e2e:db:setup   # creates + migrates + seeds ronindojo_e2e (idempotent)
#
# Local run recipe: docs/rituals/closing.md §"E2E run-evidence guard".

DATABASE_URL="postgresql://<localuser>@localhost:5432/ronindojo_e2e"
DIRECT_URL="postgresql://<localuser>@localhost:5432/ronindojo_e2e"
