{
  "name": "@ronin-dojo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "start": "next start",
    "build": "next build",
    "test": "bun test --parallel=1 --path-ignore-patterns='e2e/**'",
    "lint": "oxlint --fix .",
    "lint:check": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "next typegen && tsc --noEmit --pretty false",
    "email": "SKIP_ENV_VALIDATION=1 email dev",
    "db:generate": "prisma generate --no-hints",
    "db:migrate": "prisma migrate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push --skip-generate",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "prebuild": "bun run db:migrate deploy",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "postinstall": "bun run db:generate",
    "test:e2e": "bunx playwright test"
  },
