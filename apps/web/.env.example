NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_EMAIL=""

# Database
# For build optimization, add connection pooling parameters:
# ?connection_limit=10&pool_timeout=30
DATABASE_URL="postgresql://root@localhost/dirstarter"
DATABASE_PUBLIC_URL="" # optional; used for Next production build DB reads only when set
DIRECT_URL="" # optional locally; required in Vercel Preview/Production for Prisma migrations
SHADOW_DATABASE_URL="" # optional local shadow database for prisma migrate dev

# Cron Jobs
CRON_SECRET="xyz"

# BetterAuth
BETTER_AUTH_SECRET="xyz" # generate with `openssl rand -base64 32`
BETTER_AUTH_URL="http://localhost:3000"

# Auth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Redis
REDIS_REST_URL="" # optional
REDIS_REST_TOKEN="" # optional

# AI
AI_GATEWAY_API_KEY="" # optional; enables Vercel AI Gateway content automation
AI_CHAT_MODEL="openai/gpt-4o"
AI_COMPLETION_MODEL="openai/gpt-4o-mini"
JINA_API_KEY="" # optional

# ScreenshotOne
SCREENSHOTONE_ACCESS_KEY=""

# Resend
RESEND_API_KEY=""
RESEND_SENDER_EMAIL="welcome@baselinemartialarts.com"
RESEND_SENDER_EMAIL_BASELINE_MARTIAL_ARTS="welcome@baselinemartialarts.com"
RESEND_SENDER_EMAIL_BBL="welcome@blackbeltlegacy.com"
RESEND_SENDER_EMAIL_RONIN_DOJO_DESIGN=""
RESEND_SENDER_EMAIL_WEKAF=""
RESEND_AUDIENCE_ID=""

# Plausible
NEXT_PUBLIC_PLAUSIBLE_URL="https://plausible.io"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="" # optional override; leave blank to derive from NEXT_PUBLIC_SITE_URL
PLAUSIBLE_API_KEY=""

# Amazon S3
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""
NEXT_PUBLIC_MEDIA_BASE_URL=""

# BBL pre-launch "coming soon" gate. Set to a future ISO 8601 instant to show the
# launch countdown on BBL public routes (operator surfaces /app /admin /api stay
# open; ?preview bypasses). Unset/blank or in the past = gate off. BBL deployment only.
NEXT_PUBLIC_BBL_LAUNCH_AT=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
