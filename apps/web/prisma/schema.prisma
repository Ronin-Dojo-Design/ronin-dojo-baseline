  colorHex          String?
  // @added SESSION_0493 — degree stripes for black-belt ranks (e.g. 8 = 8th degree);
  // data-driven rendering for BeltSwatch / the lineage ancestry timeline. Null = no degree.
  degree            Int?
  // @added SESSION_0493 — second belt color for alternating-panel belts (BJJ coral
  // red/black 7th = #000000, red/white 8th = #FFFFFF; Kodokan red-white Dan belts).
  // Null = solid belt. Render-layer only, like degree — never rank authority.
  secondaryColorHex String?
  // @added SESSION_0539 — belt-family design signal driving the BeltSwatch rank-bar
  // treatment (bar color + outline). Render-layer only, never rank authority. Null for
  // non-BJJ / unseeded ranks (BeltSwatch degrades gracefully to a neutral bar).
  beltFamily        BeltFamily?
  isSystem          Boolean     @default(false)
  brand             Brand?
  createdAt         DateTime    @default(now())

  rankSystem   RankSystem @relation(fields: [rankSystemId], references: [id])
