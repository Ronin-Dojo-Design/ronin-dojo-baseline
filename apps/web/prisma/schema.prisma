// @added   SESSION_0111 (2026-05-11)
// @why     Printful POD fulfillment lifecycle states for merch orders
// @wired   MerchOrder.fulfillmentStatus, server/web/merch/, app/(web)/merch/
/// Printful POD fulfillment lifecycle.
/// @see docs/architecture/printful-pod-spec.md — MerchOrder State Machine
enum FulfillmentStatus {
  PAID /// Stripe payment received, Printful order not yet created
  SUBMITTED /// Printful API accepted the order
  PRINTING /// Printful is producing the item
  SHIPPED /// Package shipped, tracking available
  DELIVERED /// Carrier confirmed delivery (terminal — happy path)
  FAILED /// Printful could not fulfill (out of stock, print error)
  CANCELED /// Admin or customer canceled before fulfillment
  RETURNED /// Package returned to sender
  REFUNDED /// Stripe refund issued (terminal)
}

