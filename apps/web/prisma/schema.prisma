  createdAt      DateTime       @default(now())

  atom      ContentAtom     @relation(fields: [atomId], references: [id], onDelete: Cascade)
  atomId    String
  variant   ContentVariant? @relation(fields: [variantId], references: [id])
  variantId String?

  @@index([brand, channel])
  @@index([atomId])
  @@index([publishedAt])
}

