  printfulExternalId String? /// Our ID sent to Printful (= this record's id)
  fulfillmentStatus  FulfillmentStatus @default(PAID)

  /// Order details
  customerEmail String
  customerName  String?
  amountCents   Int     @default(0)
  shippingCents Int     @default(0)
  totalCents    Int     @default(0)
  currency      String  @default("USD") @db.Char(3)

  /// Line item snapshot (JSON — product name, size, color, qty, printfulVariantId)
