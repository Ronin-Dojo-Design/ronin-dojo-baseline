model WaiverSignature {
  id        String   @id @default(cuid())
  signedAt  DateTime @default(now())
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  waiver           Waiver  @relation(fields: [waiverId], references: [id], onDelete: Restrict)
  waiverId         String
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  signedOnBehalfOf User?   @relation("SignedOnBehalf", fields: [signedOnBehalfId], references: [id])
  signedOnBehalfId String?

  @@unique([waiverId, userId])
  @@index([userId])
