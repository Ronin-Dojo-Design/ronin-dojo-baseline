generator client {
  provider        = "prisma-client"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "client"
  output          = "../.generated/prisma"
}

datasource db {
  provider   = "postgresql"
  extensions = [citext]
}

enum AdType {
  Banner
  Tools
  ToolPage
  BlogPost
  Bottom
  All
}

enum ToolStatus {
  Draft
  Scheduled
  Pending
  Rejected
  Published
  Deleted
}

enum ToolTier {
  Free
  Standard
  Premium
}

enum ReportType {
  BrokenLink
  WrongCategory
  Outdated
  Other
  Feedback
}

enum PostStatus {
  Draft
  Scheduled
  Published
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("user")
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  isPlaceholder Boolean   @default(false)
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Ronin Dojo: which brand this user is currently working in
  // (drives `where: { brand }` scoping; persists across sessions)
  lastActiveBrandId Brand?

  // Relations (Dirstarter template)
  accounts  Account[]
  sessions  Session[]
  tools     Tool[]
  bookmarks Bookmark[]

  // Relations (Ronin Dojo)
  passport                   Passport?
  directoryProfile           DirectoryProfile?
  memberships                Membership[]
  rankAwards                 RankAward[]                 @relation("EarnedBy")
  awardedRankAwards          RankAward[]                 @relation("AwardedBy")
  ownedOrganizations         Organization[]              @relation("OrganizationOwner")
  lineageTreeAccessGrants    LineageTreeAccess[]         @relation("LineageTreeAccessUser")
  lineageTreeAccessGranted   LineageTreeAccess[]         @relation("LineageTreeAccessGrantedBy")
  lineageClaimRequests       LineageClaimRequest[]       @relation("LineageClaimClaimant")
  reviewedLineageClaims      LineageClaimRequest[]       @relation("LineageClaimReviewer")
  gamificationLog            GamificationEvent[]
  registrations              Registration[]
  subscriptions              UserBrandSubscription[]
  lineageNode                LineageNode?
  courseEnrollments          CourseEnrollment[]
  waiverSignatures           WaiverSignature[]
  waiverSignaturesOnBehalf   WaiverSignature[]           @relation("SignedOnBehalf")
  tournamentStaffAssignments TournamentStaffAssignment[]
  certifications             Certification[]
  issuedCertifications       Certification[]             @relation("CertIssuedBy")
  createdStyles              Style[]                     @relation("StyleCreatedBy")
  approvedStyles             Style[]                     @relation("StyleApprovedBy")
  verifiedItemCompletions    CurriculumItemCompletion[]  @relation("ItemVerifiedBy")
  createdContentAtoms        ContentAtom[]               @relation("AtomCreatedBy")
  assignedContentTasks       ContentTask[]               @relation("TaskAssignee")
  programEnrollments         ProgramEnrollment[]
  classInstructorAssignments ClassInstructorAssignment[]
  substituteClassSessions    ClassSession[]              @relation("ClassSessionSubstituteInstructor")
  attendances                Attendance[]
  checkIns                   CheckIn[]
  beltTestRegistrations      BeltTestRegistration[]
  familyMemberships          FamilyMember[]
  invoices                   Invoice[]
  contracts                  MembershipContract[]
  notificationPreferences    NotificationPreference[]
  payoutSplits               PayoutSplit[]
  stripeCustomers            StripeCustomer[]

  // Wave B relations
  createdInvites     Invite[]            @relation("InviteCreatedBy")
  inviteClaims       InviteClaim[]
  eventRegistrations EventRegistration[]
  fightRecords       FightRecord[]
  auditLogs          AuditLog[]

  // Wave C relations
  leadFollowUps  LeadFollowUp[]  @relation("FollowUpAssignee")
  weighInRecords WeighInRecord[]

  // Wave D relations
  uploadedMedia          Media[]               @relation("MediaUploadedBy")
  favorites              Favorite[]
  studentListMemberships StudentListMember[]
  createdStudentLists    StudentList[]         @relation("ListCreatedBy")
  techniqueProgress      TechniqueProgress[]
  verifiedTechProgress   TechniqueProgress[]   @relation("TechProgressVerifiedBy")
  certificateOrders      CertificateOrder[]
  certificateIssuances   CertificateIssuance[]

  // Entitlement layer
  entitlements UserEntitlement[]

  // Merch / POD
  merchOrders MerchOrder[]

  // Blog
  posts Post[]

  // GDPR / privacy
  dataSubjectRequests          DataSubjectRequest[] @relation("DataSubjectRequestSubmitter")
  dataSubjectRequestsFulfilled DataSubjectRequest[] @relation("DataSubjectRequestFulfiller")

  // Indexes
  @@index([id])
}

model Session {
  id             String   @id @default(cuid())
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Ad {
  id          String   @id @default(cuid())
  email       String
  name        String
  description String?
  websiteUrl  String
  faviconUrl  String?
  bannerUrl   String?
  buttonLabel String?
  type        AdType   @default(All)
  startsAt    DateTime
  endsAt      DateTime
  sessionId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id             String     @id @default(cuid())
  name           String     @db.Citext
  slug           String     @unique
  websiteUrl     String
  affiliateUrl   String?
  tagline        String?
  description    String?
  content        String?
  faviconUrl     String?
  screenshotUrl  String?
  isFeatured     Boolean    @default(false)
  tier           ToolTier   @default(Free)
  tierPriority   Int        @default(dbgenerated())
  submitterName  String?
  submitterEmail String?
  submitterNote  String?
  status         ToolStatus @default(Draft)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  categories   Category[]
  tags         Tag[]
  reports      Report[]
  bookmarks    Bookmark[]
  owner        User?         @relation(fields: [ownerId], references: [id])
  ownerId      String?
  posts        Post[]
  contentAtoms ContentAtom[]

  @@index([id, slug])
  @@index([name])
  @@index([status])
  @@index([ownerId])
  @@index([tierPriority, publishedAt])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @db.Citext
  slug        String   @unique
  label       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Implicit relation
  tools Tool[]

  // Indexes
  @@index([slug])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @db.Citext
  slug      String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  // Relations
  tools        Tool[]
  contentAtoms ContentAtom[]

  // Indexes
  @@index([name])
}

model Report {
  id        String     @id @default(cuid())
  type      ReportType @default(Other)
  message   String?
  email     String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  tool   Tool?   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId String?

  // Indexes
  @@index([toolId])
}

model Bookmark {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId String

  // Indexes
  @@unique([userId, toolId])
  @@index([userId])
  @@index([toolId])
}

// =============================================================================
// RONIN DOJO PLATFORM MODELS
// =============================================================================
// Everything below is the Ronin Dojo martial-arts platform schema.
// The models above (Tool, Category, Tag, Report, Ad) come from the Dirstarter
// directory template and are kept intact during the learning phase as a working
// reference for Prisma patterns — citext, indexes, owner relations, soft enums,
