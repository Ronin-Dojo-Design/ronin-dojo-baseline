// ---------------------------------------------------------------------------
// Models — Directory Profile
// ---------------------------------------------------------------------------

model Passport {
  id                        String    @id @default(cuid())
  displayName               String?
  legalFirstName            String?
  legalLastName             String?
  dob                       DateTime? @db.Date
  gender                    Gender?
  phoneE164                 String?
  emergencyContactName      String?
  emergencyContactPhoneE164 String?
  avatarUrl                 String?
  bio                       String?
  socialLinks               Json?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  // @added   SESSION_0289 (2026-05-29)
  // @why     Wire MediaAttachment back-relation (D4 resolved: all 8 FK columns now have Prisma relations)
  // @wired   server/admin/media/actions.ts (attachMedia/detachMedia), server/admin/media/queries.ts
  mediaAttachments MediaAttachment[]
}

model DirectoryProfile {
  id              String              @id @default(cuid())
  slug            String?             @unique
  visibility      DirectoryVisibility @default(MEMBERS_ONLY)
  locationCity    String?
  locationRegion  String?
  locationCountry String?             @db.Char(2)
  showEmail       Boolean             @default(false)
  showPhone       Boolean             @default(false)
  showOrgs        Boolean             @default(true)
  showRanks       Boolean             @default(true)
  coverPhotoUrl   String?
  videoIntroUrl   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
}

// ---------------------------------------------------------------------------
// Models — Organization + Discipline
// ---------------------------------------------------------------------------

model Organization {
  id           String           @id @default(cuid())
  brand        Brand
  name         String
  slug         String
  description  String?
  type         OrganizationType @default(DOJO)
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zip          String?
  country      String?          @default("US")
  websiteUrl   String?
  phoneE164    String?
  email        String?
  inviteCode   String?          @unique @default(cuid())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  owner                 User?                        @relation("OrganizationOwner", fields: [ownerId], references: [id])
  ownerId               String?
  disciplines           OrganizationDiscipline[]
  memberships           Membership[]
  courses               Course[]
  tournaments           Tournament[]
  waivers               Waiver[]
  certifications        Certification[]
  gamificationEvents    GamificationEvent[]
  contentAtoms          ContentAtom[]
  programs              Program[]
  classSchedules        ClassSchedule[]
  beltTestEvents        BeltTestEvent[]
  beltTestPrereqConfigs BeltTestPrerequisiteConfig[]
  invoices              Invoice[]
  contracts             MembershipContract[]
  pricingPlans          PricingPlan[]
  promoCodes            PromoCode[]
  stripeAccount         StripeAccount?
  orgSettings           OrgSettings?
  announcements         Announcement[]
  parentRelationships   OrgRelationship[]            @relation("OrgChild")
  childRelationships    OrgRelationship[]            @relation("OrgParent")

  // Wave B relations
  invites   Invite[]
  events    Event[]
  auditLogs AuditLog[]

  // Wave C relations
  leads Lead[]

  // Wave D relations
  media                Media[]
  techniques           Technique[]
  studentLists         StudentList[]
  certificateTemplates CertificateTemplate[]
  lineageTrees         LineageTree[]
  // @added   SESSION_0289 (2026-05-29)
  // @why     Wire MediaAttachment back-relation (D4)
  mediaAttachments     MediaAttachment[]

  // Merch / POD
  merchOrders MerchOrder[]

  // @added   SESSION_0311 (2026-05-30) — lineage Phase 3-0
  // @why     Awarding-school link for promotions (RankAward.organizationId); extends ADR 0016
  rankAwards RankAward[]

  @@unique([brand, slug])
  @@index([brand])
  @@index([ownerId])
}

model Discipline {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String
  code                   String?
  isSystem               Boolean  @default(false)
  brand                  Brand?
  defaultInstructorTitle String?
  // @added   SESSION_0124 (2026-05-11)
  // @why     Discipline enrichment: founder, year, history for detail page
  // @wired   server/web/disciplines/queries.ts, app/(web)/disciplines/[slug]/page.tsx
  foundedBy              String?
  yearEstablished        Int?
  history                String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  organizations         OrganizationDiscipline[]
  rankSystems           RankSystem[]
  courses               Course[]
  memberships           Membership[]
  programs              Program[]
  classSchedules        ClassSchedule[]
  tournamentDisciplines TournamentDiscipline[]
  styles                Style[]
  gamificationEvents    GamificationEvent[]
  contentAtoms          ContentAtom[]

  // Wave B/C/D relations
  events       Event[]
  fightRecords FightRecord[]
  ruleSets     RuleSet[]
  techniques   Technique[]

  gearRecommendations GearRecommendation[]
  lineageTrees        LineageTree[]

  @@unique([code, brand])
  @@unique([name, brand])
  @@index([brand])
}

model OrganizationDiscipline {
  organizationId String
  disciplineId   String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  discipline   Discipline   @relation(fields: [disciplineId], references: [id], onDelete: Cascade)

  @@id([organizationId, disciplineId])
}

// ---------------------------------------------------------------------------
// Models — Rank system
// ---------------------------------------------------------------------------

model RankSystem {
  id        String         @id @default(cuid())
  name      String
  kind      RankSystemKind @default(BELT)
  isSystem  Boolean        @default(false)
  brand     Brand?
  createdAt DateTime       @default(now())

