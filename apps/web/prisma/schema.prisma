model MediaAttachment {
  id        String   @id @default(cuid(2))
  purpose   String?
  sortOrder Int      @default(0)
  // @added SESSION_0527 Slice 0 — per-video freemium. The gate unit is now the ATTACHMENT so a single
  // technique can mix free + premium clips (operator decision, SESSION_0526 Fork 2). Backfilled from the
  // parent Technique.isPremium (behavior-preserving); default false — non-technique attachments
  // (podcasts/matches/events) were never premium. Preserves the SESSION_0526 A1/A2 no-leak invariants:
  // a locked premium attachment's playable url is stripped server-side before any client payload.
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())

  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  mediaId String

  passportId            String?
  techniqueId           String?
  eventId               String?
  rankAwardId           String?
  rankMilestoneId       String?
  courseId              String?
  organizationId        String?
  contentAtomId         String?
  certificateTemplateId String?
  // @added SESSION_0318 (2026-05-31) — shared PromotionEvent gallery (polymorphic per-owner pattern)
  promotionEventId      String?

  // @added   SESSION_0289 (2026-05-29)
  // @why     D4 resolved: wire all 8 FK columns to full Prisma relations (5 were bare id-only)
  // @wired   server/admin/media/actions.ts (attachMedia/detachMedia), server/admin/media/queries.ts
  passport            Passport?            @relation(fields: [passportId], references: [id])
  technique           Technique?           @relation(fields: [techniqueId], references: [id])
  event               Event?               @relation(fields: [eventId], references: [id])
  rankAward           RankAward?           @relation(fields: [rankAwardId], references: [id])
  rankMilestone       RankMilestone?       @relation(fields: [rankMilestoneId], references: [id])
  course              Course?              @relation(fields: [courseId], references: [id])
  organization        Organization?        @relation(fields: [organizationId], references: [id])
  contentAtom         ContentAtom?         @relation(fields: [contentAtomId], references: [id])
  certificateTemplate CertificateTemplate? @relation(fields: [certificateTemplateId], references: [id])
  promotionEvent      PromotionEvent?      @relation(fields: [promotionEventId], references: [id])

  @@index([mediaId])
  @@index([passportId])
  @@index([techniqueId])
  @@index([eventId])
  @@index([rankAwardId])
  @@index([rankMilestoneId])
  @@index([courseId])
  @@index([organizationId])
  @@index([contentAtomId])
  @@index([certificateTemplateId])
  @@index([promotionEventId])
}

model Technique {
  id                String             @id @default(cuid(2))
  brand             Brand
  name              String
  slug              String
  description       String?
  position          TechniquePosition?
  category          TechniqueCategory?
  difficultyLevel   DifficultyLevel?
  isGi              Boolean?
  isFoundational    Boolean            @default(false)
  requiresPartner   Boolean            @default(false)
  requiresEquipment Boolean            @default(false)
  movementPattern   String?
  rangeBand         String?
  teachingCues      String[]
  commonErrors      String[]
  safetyNotes       String?
  isPublished       Boolean            @default(false)
  // @added SESSION_0525 — technique freemium (locked-preview). Default premium: most
  // curriculum content is gated; a free-preview subset is flipped to false by the seed.
  // Drives the browse-card lock badge + the watch-page/profile-rail entitlement gate.
  isPremium         Boolean            @default(true)
  // @added SESSION_0528 (ADR 0046 D4) — staff "promote to library" flips this; an authored
  // profile-only technique (org null, not featured) stays OFF the canonical browse/rails/watch
  // discovery until featured, while keeping its `authorPassportId` attribution.
  isFeatured        Boolean            @default(false)
  sortOrder         Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now())

  discipline       Discipline    @relation(fields: [disciplineId], references: [id])
  disciplineId     String
  // @changed SESSION_0528 (ADR 0046 D1) — organizationId is now the author's SCHOOL and is
  // nullable (null = profile-only, ungrouped). Existing library techniques keep their org.
  // onDelete stays Cascade (unchanged) — deleting a school removes its techniques as before.
  // @changed SESSION_0528 (ADR 0046 D1, Doug P2) — SetNull, not Cascade: the org is a SOFT grouping
  // (the author's school), the Passport is the owner. Deleting a school DEMOTES its techniques to
  // profile-only (organizationId → null), never destroys a member's authored curriculum.
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId   String?
  // @added SESSION_0528 (ADR 0046 D2) — authored-by Passport carries ownership + per-author
  // variants. null = canonical / org-seeded (the existing library). onDelete: SetNull un-authors
  // (never deletes) the row when a person is removed.
  author           Passport?     @relation(fields: [authorPassportId], references: [id], onDelete: SetNull)
  authorPassportId String?
  style            Style?        @relation(fields: [styleId], references: [id])
  styleId          String?
  beltLevelMin     Rank?         @relation("TechBeltMin", fields: [beltLevelMinId], references: [id])
  beltLevelMinId   String?
  beltLevelMax     Rank?         @relation("TechBeltMax", fields: [beltLevelMaxId], references: [id])
  beltLevelMaxId   String?

  // @added   Wave D (SESSION_0026)
  // @why     Technique ↔ MediaAttachment relation for attaching media to techniques
  mediaAttachments   MediaAttachment[]
  curriculumLinks    TechniqueCurriculumLink[]
  prerequisiteFor    TechniquePrerequisite[]   @relation("TechPrereqTarget")
  prerequisites      TechniquePrerequisite[]   @relation("TechPrereqSource")
  progress           TechniqueProgress[]
  gamificationEvents GamificationEvent[]

  // @added SESSION_0396 — shared listing taxonomy (Tool→Listing parity, ADR 0013 superseded).
  // Relational Category/Tag (slug-based directory taxonomy) — distinct from the `category`
  // TechniqueCategory enum above (positional). Powers /techniques/categories/[slug] + /tags/[slug].
  categories Category[]
  tags       Tag[]

  // @added SESSION_0397 — polymorphic Bookmark (Save persistence). subjectType=TECHNIQUE.
  bookmarks Bookmark[]

  // @changed SESSION_0528 (ADR 0046 D3) — the composite `@@unique([brand, organizationId, slug])`
  // is REPLACED by two PARTIAL unique indexes created in the migration SQL:
  //   canonical: UNIQUE (brand, organizationId, slug) WHERE authorPassportId IS NULL
  //   authored:  UNIQUE (brand, authorPassportId, slug) WHERE authorPassportId IS NOT NULL
  // Prisma cannot express a partial WHERE in `@@unique`, so they are DB-managed and intentionally
  // absent here. Verified SESSION_0528: `prisma migrate diff` (schema ↔ DB) ignores filtered/partial
  // indexes entirely and reports ZERO Technique drift — they are invisible to Prisma tooling, not
  // flagged. Regardless, migrations are hand-authored + shadow-replayed — never `migrate dev` on the
  // shared local DB (it would reset it). See the migration file.
  @@index([brand, disciplineId])
  @@index([position, category])
  @@index([disciplineId, difficultyLevel])
  @@index([authorPassportId])
}

