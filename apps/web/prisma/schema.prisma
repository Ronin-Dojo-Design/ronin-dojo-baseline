// ---------------------------------------------------------------------------
// Models — Content Engine
// ---------------------------------------------------------------------------
// The Content Atom is the smallest reusable unit of teaching/marketing content.
// One atom stores the canonical truth; variants adapt it per brand × channel.
// Tasks track operational workflow; publications track what went live where.
// ---------------------------------------------------------------------------

model ContentAtom {
  id                String             @id @default(cuid())
  canonicalId       String             @unique /// e.g. atom-2026-cross-training-001
  title             String
  slug              String
  status            ContentAtomStatus  @default(INBOX)
  hook              String?
  promise           String?
  proof             String?
  cta               String?
  oneSentenceValue  String? /// Core teaching content (markdown)
  teachingTruth     String? /// Core teaching content (markdown)
  longFormCopy      String? /// Full article/lesson body (markdown)
  curriculumExtract Json? /// Structured: objective, movements, drills, cues
  videoExtract      Json? /// Structured: teaser, reel outline, lesson outline
  siteTargets       Brand[] /// Which brands this atom targets
  channelTargets    ContentChannel[] /// Which channels this atom targets
  qualityScore      Int? /// 0-10 editorial quality rating
  sourceType        ContentSourceType?
  sourceAssets      String[] /// URLs/paths to source media
  meta              Json? /// Extensible metadata
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  createdBy      User          @relation("AtomCreatedBy", fields: [createdById], references: [id])
  createdById    String
  discipline     Discipline?   @relation(fields: [disciplineId], references: [id])
  disciplineId   String?
  style          Style?        @relation(fields: [styleId], references: [id])
  styleId        String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  variants         ContentVariant[]
  tasks            ContentTask[]
  publications     ContentPublication[]
  tags             Tag[]
  tools            Tool[]
  // @added   Wave D (SESSION_0026)
  // @why     ContentAtom ↔ MediaAttachment relation for attaching media to content atoms
  mediaAttachments MediaAttachment[]

  @@unique([slug])
  @@index([status])
  @@index([createdById])
  @@index([disciplineId])
  @@index([organizationId])
}

model ContentVariant {
  id           String               @id @default(cuid())
  brand        Brand
  channel      ContentChannel
  status       ContentVariantStatus @default(DRAFT)
  publicTitle  String?
  publicSlug   String?
  renderedCopy String? /// Channel-formatted output (markdown/html)
  excerpt      String?
  cta          String?
  thumbnailUrl String?
  videoUrl     String?
  voiceNotes   String? /// Brand voice adaptation notes
  meta         Json?
  publishDate  DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  atom   ContentAtom @relation(fields: [atomId], references: [id], onDelete: Cascade)
  atomId String

  publications ContentPublication[]

  @@unique([atomId, brand, channel])
  @@index([brand, channel, status])
  @@index([atomId])
}

model ContentTask {
  id          String            @id @default(cuid())
  type        ContentTaskType
  title       String
  status      ContentTaskStatus @default(TODO)
  priority    Int               @default(0) /// Higher = more urgent
  notes       String?
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now())

  atom         ContentAtom   @relation(fields: [atomId], references: [id], onDelete: Cascade)
  atomId       String
  assignee     User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId   String?
  dependsOn    ContentTask?  @relation("TaskDependency", fields: [dependsOnId], references: [id])
  dependsOnId  String?
  dependedOnBy ContentTask[] @relation("TaskDependency")

  @@index([atomId, status])
  @@index([assigneeId, status])
  @@index([dueAt])
}

model ContentPublication {
  id             String         @id @default(cuid())
  brand          Brand
  channel        ContentChannel
