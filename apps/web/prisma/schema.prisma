  claims InviteClaim[]

  @@index([brand, organizationId])
  @@index([code])
  @@index([createdById])
}

model InviteClaim {
  id        String   @id @default(cuid())
  claimedAt DateTime @default(now())

  invite   Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
