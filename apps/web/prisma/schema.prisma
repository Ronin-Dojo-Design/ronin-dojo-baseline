// ---------------------------------------------------------------------------
// Models — Directory Profile
// ---------------------------------------------------------------------------

model Passport {
  id                        String    @id @default(cuid(2))
  displayName               String?
  legalFirstName            String?
  legalLastName             String?
  dob                       DateTime? @db.Date
  gender                    Gender?
  phoneE164                 String?
  emergencyContactName      String?
  emergencyContactPhoneE164 String?
  avatarUrl                 String?
  bio                       String?
  socialLinks               Json?
  // @added SESSION_0357 — Passport is the identity source of truth (passport-and-shells.md).
  // coverPhoto/videoIntro are identity media moved off DirectoryProfile (the presentation *view*);
  // placeOfBirth/startedTrainingAt come from the BBL Pods `bbl_member` model. Schools/rank are NOT
  // here — school is a person↔org relationship (deferred) and rank derives from RankAward.
  coverPhotoUrl             String?
  videoIntroUrl             String?
  placeOfBirth              String?
  // @added SESSION_0409 — BBL Pods full-fidelity import (BBL_PODS_FULL_IMPORT_SPEC.md). The Pods
  // `current_place_of_residence` field had no home in the schema; placeOfBirth already exists, so
  // this is the one genuine new profile column the re-import needs. Enriched non-destructively.
  currentResidence          String?
  startedTrainingAt         DateTime? @db.Date
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique

  // @added SESSION_0396 — shared listing taxonomy (Tool→Listing parity). Person-level
  // categories/tags for /members/categories/[slug]; Passport stays the identity SoT (ADR 0025).
  categories Category[]
  tags       Tag[]

  // @added SESSION_0397 — polymorphic Bookmark (Save persistence). Person = Passport (the SoT
  // that feeds DirectoryProfile + lineage + board); subjectType=PERSON keys here.
  bookmarks Bookmark[]

  // @added   SESSION_0289 (2026-05-29)
  // @why     Wire MediaAttachment back-relation (D4 resolved: all 8 FK columns now have Prisma relations)
  // @wired   server/admin/media/actions.ts (attachMedia/detachMedia), server/admin/media/queries.ts
  mediaAttachments MediaAttachment[]

  // @added SESSION_0390 (Phase 3a) — Passport-rooted identity satellites (SOT-ADR D1). Additive,
  // nullable back-relations alongside the existing User links. The satellite FKs flip to NOT NULL and
  // the old userId columns drop in Phase 3b. FightRecord was promoted to a 5th satellite (operator,
  // SESSION_0390 grill). `userId` is now nullable: an accountless Passport = the placeholder.
  directoryProfile        DirectoryProfile?
  lineageNode             LineageNode?
  affiliations            Affiliation[]
  rankAwardsEarned        RankAward[]
  rankAwardsPromoted      RankAward[]       @relation("PromotedByPassport")
  rankEntries             RankEntry[]
  expectedPromoterReviews RankEntryReview[] @relation("RankEntryReviewExpectedPromoter")
  proposedPromoterReviews RankEntryReview[] @relation("RankEntryReviewProposedPromoter")
  fightRecords            FightRecord[]

  // @added SESSION_0437 (ADR 0036) — unified person claim keyed on identity.
  claimRequests PassportClaimRequest[]

  // @added SESSION_0498 (Epic A) — 1:0..1 story-scene satellite for the lineage scroll story.
  storyScene LineageStoryScene?

  // @added SESSION_0528 (ADR 0046 D2) — techniques this person authored (their profile curriculum,
  // `where authorPassportId = me`). Back-relation for `Technique.author`.
  authoredTechniques Technique[]
}

model DirectoryProfile {
  id              String              @id @default(cuid(2))
  slug            String?             @unique
  visibility      DirectoryVisibility @default(MEMBERS_ONLY)
  locationCity    String?
  locationRegion  String?
  locationCountry String?             @db.Char(2)
  showEmail       Boolean             @default(false)
  showPhone       Boolean             @default(false)
  showOrgs        Boolean             @default(true)
  showRanks       Boolean             @default(true)
  coverPhotoUrl   String?
  videoIntroUrl   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // @changed SESSION_0392 (Phase 3c) — Passport is the identity root (SOT-ADR D1); the old
  // `user`/`userId` satellite FK was dropped. `passportId` is the canonical @unique NOT NULL link.
  // onDelete: Cascade mirrors the old User cascade (deleting a person removes their satellites).
  passport              Passport               @relation(fields: [passportId], references: [id], onDelete: Cascade)
  passportId            String                 @unique
  claimRequests         ProfileClaimRequest[]
  // @added SESSION_0437 (ADR 0036) — unified claim back-relation (directory door context).
  passportClaimRequests PassportClaimRequest[]
}

