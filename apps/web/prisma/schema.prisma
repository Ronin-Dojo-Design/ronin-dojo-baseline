  roleAssignments MembershipRoleAssignment[]

  @@unique([code, brand])
  @@index([brand])
}

// @added SESSION_0357 — display-only person↔org affiliation (NO payment here). A person is
// affiliated with one or more Organizations: their school(s)/dojo(s) and any umbrella AFFILIATION
// org (e.g. CSW, Rigan Machado Affiliation). `organization` is the verified link; `schoolName` is
// the free-text fallback for an unverified school (the "pick a verified school OR type one" capture
// from the BBL registration form). A person has many. Distinct from Membership (paid Baseline
// enrollment) and from RankAward.organization (the school that awarded a belt).
enum AffiliationRole {
  TRAINS_AT
  TEACHES_AT
  HEAD_INSTRUCTOR
  OWNER
  MEMBER
}

model Affiliation {
  id         String          @id @default(cuid(2))
  role       AffiliationRole @default(TRAINS_AT)
  isCurrent  Boolean         @default(true)
  schoolName String?
  startedAt  DateTime?       @db.Date
  endedAt    DateTime?       @db.Date
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  // @changed SESSION_0392 (Phase 3c) — Passport is the identity root (SOT-ADR D1); the old
  // `user`/`userId` satellite FK was dropped. `passportId` is the canonical link (non-unique;
  // a person has many affiliations). onDelete: Cascade mirrors the old User cascade.
  passport       Passport      @relation(fields: [passportId], references: [id], onDelete: Cascade)
  passportId     String
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId String?

  @@index([passportId, isCurrent])
  @@index([organizationId])
}

