// ---------------------------------------------------------------------------
// Models — Rank awards
// ---------------------------------------------------------------------------

// @added SESSION_0357 (BBL-RANK-004) — RankAward is the single rank source (ADR 0016).
// `source` distinguishes a STATED lineage rank (operator: "you don't earn it here, it's verified")
// from an EARNED gamification award; `verificationStatus` is the stated→verified workflow driven by
// an admin / RBAC editor (TREE_ADMIN / TREE_EDITOR / BRANCH_EDITOR). IMPORTED = legacy migration.
enum RankAwardSource {
  STATED
  EARNED
}

enum RankAwardVerificationStatus {
  UNVERIFIED
  VERIFIED
  DISPUTED
  IMPORTED
}

enum RankEntryStatus {
  PENDING
  UNVERIFIED
  VERIFIED
  DISPUTED
}

enum RankEntryReviewStatus {
  PENDING
  APPROVED
  DENIED
  // @added   SESSION_0542 (2026-07-16)
  // @why     Prevent rolling legacy decision writers from consuming immutable promoter proposals
  // @wired   server/belt/promoter-proposal-core.ts, server/admin/rank-reviews/actions.ts
  /// Captured active-first promoter proposal. Kept distinct from legacy PENDING so a rolling old
  /// decision writer cannot approve the row without applying its immutable proposed promoter.
  PROPOSAL_PENDING
}

enum RankEntryReviewReason {
  NEW_RANK
  PROMOTER_CHANGED
  SCHOOL_CHANGED
  DISPUTE
}

model RankAward {
  id                 String                      @id @default(cuid(2))
  awardedAt          DateTime?
  notes              String?
  location           String?
  /// @deprecated Use RankMilestone + MediaAttachment.rankMilestoneId for belt journey media/story enrichment.
  mediaUrls          Json?
  source             RankAwardSource             @default(STATED)
  verificationStatus RankAwardVerificationStatus @default(UNVERIFIED)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  // @changed SESSION_0392 (Phase 3c) — Passport is the identity root for the EARNER (SOT-ADR D1;
  // RankAward is DUAL). The old earner `user`/`userId` FK was dropped; `passportId` is canonical
  // (onDelete: Cascade mirrors the old User cascade). The promoter link (awardedBy/awardedById)
  // STAYS on User — it is an acting account.
  passport            Passport      @relation(fields: [passportId], references: [id], onDelete: Cascade)
  passportId          String
  rank                Rank          @relation(fields: [rankId], references: [id], onDelete: Restrict)
  rankId              String
  awardedBy           User?         @relation("AwardedBy", fields: [awardedById], references: [id])
  awardedById         String?
  // @added SESSION_0391 (Phase 3b) — historical promoter identity. `awardedById` remains a real
  // account actor/authority FK; placeholder promoters copy here, then their synthetic User FK is
  // nulled before placeholder Users are hard-deleted.
  awardedByPassport   Passport?     @relation("PromotedByPassport", fields: [awardedByPassportId], references: [id])
  awardedByPassportId String?
  // @added   SESSION_0311 (2026-05-30) — lineage Phase 3-0; awarding school (extends ADR 0016).
  // RankAward stays the canonical promotion fact; `organization` is the school that awarded this belt
  // — distinct from `awardedBy` (the promoter) and from the member's current Membership/affiliation.
  // Nullable; free-text `location` retained as fallback. onDelete: SetNull so removing an org never
  // drops promotion history.
  organization        Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizationId      String?

  // @added   SESSION_0318 (2026-05-31) — PromotionEvent grouping fact (extends ADR 0016).
  // RankAward stays the canonical per-person promotion fact; `promotionEvent` (nullable) groups
  // multiple people's awards into one ceremony. onDelete: SetNull so removing an event never drops
  // promotion history. See docs/architecture/decisions/0016 → SESSION_0318 amendment.
  promotionEvent   PromotionEvent? @relation(fields: [promotionEventId], references: [id], onDelete: SetNull)
  promotionEventId String?

  lineageRelationships LineageRelationship[]
  gamificationEvents   GamificationEvent[]
  // @added   SESSION_0289 (2026-05-29)
  // @why     Wire MediaAttachment back-relation (D4)
  mediaAttachments     MediaAttachment[]
  // @added   SESSION_0479 (2026-07-01)
  // @why     Belt Journey enrichment lives beside the canonical RankAward fact, not inside it.
  milestone            RankMilestone?
  // @added SESSION_0518 — additive migration anchor for the unified RankEntry aggregate.
  rankEntry            RankEntry?

  @@unique([passportId, rankId])
  @@index([passportId, awardedAt])
  @@index([rankId])
  @@index([awardedById])
  @@index([awardedByPassportId])
  @@index([organizationId])
  @@index([promotionEventId])
}

/// Canonical member rank aggregate. The first migration keeps RankAward as its
/// compatibility anchor while authenticated profile reads and writes move over.
model RankEntry {
  id        String          @id @default(cuid(2))
  status    RankEntryStatus @default(UNVERIFIED)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  passportId String
  rank       Rank     @relation(fields: [rankId], references: [id], onDelete: Restrict)
  rankId     String

  /// Temporary one-to-one migration anchor; remove only after legacy cutover.
  rankAward   RankAward @relation(fields: [rankAwardId], references: [id], onDelete: Cascade)
  rankAwardId String    @unique

  reviews RankEntryReview[]

  @@unique([passportId, rankId])
  @@index([passportId, status])
  @@index([rankId])
}

/// Steward workflow contract for higher-rank and proposed promoter/school changes.
model RankEntryReview {
  id                         String                @id @default(cuid(2))
  status                     RankEntryReviewStatus @default(PENDING)
  reason                     RankEntryReviewReason
  note                       String?
  // @added   SESSION_0542 (2026-07-16)
  // @why     Preserve the accepted and proposed promoter identities as an immutable decision snapshot
  // @wired   server/belt/promoter-proposal-core.ts, server/admin/rank-reviews/queries.ts
  /// Captures the immutable proposal snapshot boundary. Null means a legacy review without payload.
  proposalCapturedAt         DateTime?
  /// Active promoter identity/name observed when the proposal was captured.
  expectedPromoterPassportId String?
  expectedPromoterName       String?
  /// Proposed established-coach identity. Nullable only for additive rollout / legacy rows.
  proposedPromoterPassportId String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  rankEntry        RankEntry @relation(fields: [rankEntryId], references: [id], onDelete: Cascade)
  rankEntryId      String
  expectedPromoter Passport? @relation("RankEntryReviewExpectedPromoter", fields: [expectedPromoterPassportId], references: [id], onDelete: Restrict)
  proposedPromoter Passport? @relation("RankEntryReviewProposedPromoter", fields: [proposedPromoterPassportId], references: [id], onDelete: Restrict)

  @@index([rankEntryId, status])
  @@index([status, reason])
  @@index([expectedPromoterPassportId])
  @@index([proposedPromoterPassportId])
}

// @added SESSION_0479 (2026-07-01) — member-owned belt journey enrichment.
// RankAward remains the canonical promotion fact (ADR 0016); this model stores editable story/media
// enrichment only and carries no verification or rank authority.
model RankMilestone {
  id        String   @id @default(cuid(2))
  story     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rankAward   RankAward @relation(fields: [rankAwardId], references: [id], onDelete: Cascade)
  rankAwardId String    @unique

  media MediaAttachment[]
}

// ---------------------------------------------------------------------------
// Model — PromotionEvent (belt ceremony grouping fact)
// ---------------------------------------------------------------------------

// @added SESSION_0318 (2026-05-31) — first-class ceremony that groups multiple RankAwards into one
// event with a shared date, host venue, description, and shared media gallery. RankAward remains the
// canonical promotion fact (ADR 0016); PromotionEvent sits above it as an OPTIONAL grouping. The event
// carries NO verification signal — verification stays role-gated on RankAward/LineageRelationship.
// No attestor/attendee model in v1 (promoter is RankAward.awardedById; uploader is Media.uploadedById).
// Discipline-agnostic: one ceremony can group awards across BJJ / FMA-WEKAF / Muay Thai etc.
model PromotionEvent {
  id          String   @id @default(cuid(2))
  title       String
  // @added SESSION_0319 (2026-06-01) — stable public route key for `/events/[slug]`.
  // Nullable so the migration is additive; seed backfills canonical ceremony slugs.
  slug        String?  @unique
  eventDate   DateTime
  location    String? // free-text venue fallback
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // host venue (where held), distinct from each RankAward.organizationId (awarding school of record)
  hostOrganization   Organization? @relation("PromotionEventHostOrg", fields: [hostOrganizationId], references: [id], onDelete: SetNull)
  hostOrganizationId String?

  rankAwards       RankAward[]
  mediaAttachments MediaAttachment[] // shared event gallery
  visualGroups     LineageVisualGroup[] // per-tree cohort boxes that represent this event

  @@index([eventDate])
  @@index([hostOrganizationId])
}

