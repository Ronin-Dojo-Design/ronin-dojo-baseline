// @added   migration 20260707000000_add_user_permission_grant (2026-07-07)
// @why     FI-019 — additive per-user global capability grants inside the existing `can()` axis
// @wired   lib/auth.ts, server/orpc/permissions.ts, server/admin/permissions/actions.ts, app/app/users/[id]/page.tsx
model UserPermissionGrant {
  id        String    @id @default(cuid(2))
  grant     String
  reason    String?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user        User    @relation("UserPermissionGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  grantedBy   User?   @relation("UserPermissionGrantGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  grantedById String?
  // NOTE: a PARTIAL unique index `(userId, grant) WHERE "revokedAt" IS NULL` — "at most one
  // LIVE grant per (user, key)" while preserving soft-revoke history — lives ONLY in
  // migration 20260707000000_add_user_permission_grant/migration.sql (Prisma can't express a
  // partial index). `migrate deploy` applies it from SQL; a `migrate diff --from-schema` that
  // flags it as "missing" is that limitation, not real drift.

  @@index([userId, revokedAt])
  @@index([grant, revokedAt])
  @@index([grantedById])
}

// @added   migration 20260517_lineage_tree_v1 (2026-05-17)
// @why     A user's request to claim a lineage node in a tree, with admin review/approval workflow
// @wired   server/web/lineage/claim-node-for-user.ts, server/admin/lineage/claim-review-actions.ts
model LineageClaimRequest {
  id           String             @id @default(cuid(2))
  status       LineageClaimStatus @default(PENDING)
  claimantNote String?
  reviewerNote String?
  bypassReason String?
  reviewedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tree           LineageTree @relation(fields: [treeId], references: [id], onDelete: Cascade)
  treeId         String
  node           LineageNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId         String
  claimant       User        @relation("LineageClaimClaimant", fields: [claimantUserId], references: [id], onDelete: Cascade)
  claimantUserId String
  reviewedBy     User?       @relation("LineageClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedById   String?
  // @added SESSION_0432 FI-006 — claimedRankId stores the rank the claimant asserts at
  // registration/claim time (PENDING state). It is NOT a RankAward — it cannot display on the
  // tree. Admin-verify creates the awarded RankAward from this field (claim→award lifecycle).
  // See ADR 0035 §4 for the structural reason: a claimed rank on the claim record cannot
  // structurally leak onto the tree as if awarded (the exact failure mode of the
  // selectedRankAward display override, removed in SESSION_0475).
  claimedRank    Rank?       @relation("ClaimedRank", fields: [claimedRankId], references: [id], onDelete: SetNull)
  claimedRankId  String?

  evidence LineageClaimEvidence[]

  @@index([treeId, status])
  @@index([nodeId, status])
  @@index([claimantUserId, status])
  @@index([claimedRankId])
}

// @added SESSION_0419 — email→node pending-claim binding. The one-click claim used to ride ONLY
// the magic-link callbackURL (/preview → /lineage/claim/accept?node=…), so a founder who signed in
// with Google (the email's *recommended* method) authenticated fine but never claimed their node.
// This row records "the invite to <email> is for <node>"; lib/auth.ts `hooks.after` reconciles it
// on EVERY successful auth (Google + magic-link), so any sign-in method claims. Idempotent: the
// magic-link route path still claims directly, and the reconciler's finalize is a no-op on replay.
// See server/web/lineage/reconcile-pending-claims.ts + mint-claim-magic-link.ts.
model LineagePendingClaim {
  id         String    @id @default(cuid(2))
  email      String // lowercased at write time — the address the claim invite was sent to
  brand      Brand
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  consumedAt DateTime?

  node             LineageNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  nodeId           String
  consumedByUser   User?       @relation("LineagePendingClaimConsumer", fields: [consumedByUserId], references: [id], onDelete: SetNull)
  consumedByUserId String?

  @@unique([email, nodeId])
  @@index([email, consumedAt])
  @@index([nodeId])
}

// @added   migration 20260517_lineage_tree_v1 (2026-05-17)
// @why     A piece of supporting evidence (link/text/media) attached to a LineageClaimRequest for review
// @wired   (no runtime consumers found — verify; written/read via LineageClaimRequest.evidence includes)
model LineageClaimEvidence {
  id        String   @id @default(cuid(2))
  label     String?
  url       String?
  text      String?
  createdAt DateTime @default(now())

  claimRequest   LineageClaimRequest @relation(fields: [claimRequestId], references: [id], onDelete: Cascade)
  claimRequestId String
  media          Media?              @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  mediaId        String?

  @@index([claimRequestId])
  @@index([mediaId])
}

// ---------------------------------------------------------------------------
// Models — Profile claims (generic member/org claim, SESSION_0354)
// ---------------------------------------------------------------------------
//
// Mirrors the LineageClaimRequest admin-review flow for the two profile
// surfaces that can legitimately be "unclaimed": owner-less Organizations and
// legacy placeholder person profiles (a DirectoryProfile whose User has no
// login account). Reuses LineageClaimStatus. The subject is polymorphic —
// exactly one of directoryProfile/organization is set, matching subjectType
// (enforced in the claim action, not the DB). Approval grants ownership/admin
// of the subject to the claimant.

enum ProfileClaimSubjectType {
  PERSON
  ORGANIZATION
}

enum ProfileClaimRelationship {
  SELF
  STAFF
  OWNER
  REPRESENTATIVE
  FAMILY
  OTHER
}

model ProfileClaimRequest {
  id           String                   @id @default(cuid(2))
  status       LineageClaimStatus       @default(PENDING)
  subjectType  ProfileClaimSubjectType
  relationship ProfileClaimRelationship
  brand        Brand
  claimantNote String?
  reviewerNote String?
  reviewedAt   DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  directoryProfile   DirectoryProfile? @relation(fields: [directoryProfileId], references: [id], onDelete: Cascade)
  directoryProfileId String?
  organization       Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId     String?

  claimant       User    @relation("ProfileClaimClaimant", fields: [claimantUserId], references: [id], onDelete: Cascade)
  claimantUserId String
  reviewedBy     User?   @relation("ProfileClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedById   String?

  @@index([brand, status])
  @@index([directoryProfileId, status])
  @@index([organizationId, status])
  @@index([claimantUserId, status])
}

// @added SESSION_0487 (petey-plan-0477 Slice V1; ADR 0035 Amendment 1 / ADR 0036) — claim-type
// discriminant. IDENTITY = the account→Passport claim (the original ADR 0036 flow). RANK_PROMOTION =
// an already-owned member asserting a belt above their verified ceiling; finalize (Slice V3) branches
// on this to run ONLY the rank-mint branch (no account-attach), flipping the asserted rank to a
// VERIFIED RankAward via mintAssertedRankAward. No UNVERIFIED RankAward is ever created (B1, ADR 0035 §5).
enum PassportClaimType {
  IDENTITY
  RANK_PROMOTION
}

// ---------------------------------------------------------------------------
// Models — Unified Passport-keyed person claim (ADR 0036, SESSION_0437)
// ---------------------------------------------------------------------------
//
// THE single person-claim record. A human is one Passport (identity SoT,
// ADR 0025); both claim doors (lineage node + directory person profile)
// resolve their subject to a `passportId` and write THIS record, so the
// duplicate guard, admin review queue, and finalize all key on identity, not
// door. Replaces the person split across LineageClaimRequest and person
// ProfileClaimRequest; carries optional door context so finalize runs the
// tree-member / NODE_EDITOR / cohort-comp / RankAward branches only when a
// lineage node is present, and un-stubs the directory-only person approval.
// Org claims stay a separate sibling in ProfileClaimRequest (an owner-less
// Organization is not a Passport). Reuses LineageClaimStatus +
// ProfileClaimRelationship. "Claimed" still means Passport.userId != null.
model PassportClaimRequest {
  id           String                    @id @default(cuid(2))
  status       LineageClaimStatus        @default(PENDING)
  // Claim kind (Slice V1). Existing rows default to IDENTITY (the ADR 0036 account→Passport claim);
  // RANK_PROMOTION = an already-owned member's belt-promotion request (finalize branches on this, V3).
  type         PassportClaimType         @default(IDENTITY)
  // relationship is optional: the lineage door does not capture one (parity
  // with LineageClaimRequest); the directory-person door passes it through.
  relationship ProfileClaimRelationship?
  brand        Brand
  claimantNote String?
  reviewerNote String?
  bypassReason String?
  reviewedAt   DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  // Identity key — NOT NULL. Deleting the person removes their claims.
  passport   Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)
  passportId String

  // Door context — all optional (SetNull): a directory-only person claim has
  // no node/tree; a lineage claim back-fills node+tree; directoryProfileId is
  // set when the directory door opened the claim.
  node               LineageNode?      @relation("PassportClaimNode", fields: [nodeId], references: [id], onDelete: SetNull)
  nodeId             String?
  tree               LineageTree?      @relation("PassportClaimTree", fields: [treeId], references: [id], onDelete: SetNull)
  treeId             String?
  directoryProfile   DirectoryProfile? @relation(fields: [directoryProfileId], references: [id], onDelete: SetNull)
  directoryProfileId String?

  claimant       User    @relation("PassportClaimClaimant", fields: [claimantUserId], references: [id], onDelete: Cascade)
  claimantUserId String
  reviewedBy     User?   @relation("PassportClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedById   String?

  // The rank the claimant asserts at claim time (PENDING) — NOT a RankAward;
  // admin-verify mints the awarded RankAward from this (claim→award, ADR 0035).
  claimedRank   Rank?   @relation("PassportClaimClaimedRank", fields: [claimedRankId], references: [id], onDelete: SetNull)
  claimedRankId String?

  // Lineage selections asserted at claim time (SESSION_0441) — same shape as claimedRank:
  // a registered combobox pick links the entity (shown to the steward as a resolved link +
  // actionable on approve); a custom entry leaves these null and only the text label (carried
  // in claimantNote) survives.
  claimedSchool      Organization? @relation("PassportClaimSchool", fields: [claimedSchoolId], references: [id], onDelete: SetNull)
  claimedSchoolId    String?
  trainedUnderNode   LineageNode?  @relation("PassportClaimTrainedUnder", fields: [trainedUnderNodeId], references: [id], onDelete: SetNull)
  trainedUnderNodeId String?
  representTree      LineageTree?  @relation("PassportClaimRepresentTree", fields: [representTreeId], references: [id], onDelete: SetNull)
  representTreeId    String?

  evidence PassportClaimEvidence[]

  @@index([brand, status])
  @@index([passportId, status])
  @@index([nodeId, status])
  @@index([directoryProfileId, status])
  @@index([claimantUserId, status])
}

// @added SESSION_0437 (ADR 0036) — mirrors LineageClaimEvidence for the unified claim.
model PassportClaimEvidence {
  id        String   @id @default(cuid(2))
  label     String?
  url       String?
  text      String?
  createdAt DateTime @default(now())

  claimRequest   PassportClaimRequest @relation(fields: [claimRequestId], references: [id], onDelete: Cascade)
  claimRequestId String
  media          Media?               @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  mediaId        String?

  @@index([claimRequestId])
  @@index([mediaId])
}

