// Platform-level user role (Better Auth `admin()` plugin owns this field).
// Typed enum (was free-text String) so a typo can't silently bypass an authz gate.
// `lineage_tree_admin` is intentionally NOT here — it's a synthetic UI label derived
// from the separate LineageTreeAccess table, never stored on User.role. Keep roles
// single-valued (Better Auth array-roles would emit "a,b", invalid for an enum column).
enum UserRole {
  user
  admin
  tournament_director
}

model User {
  id            String    @id @default(cuid(2))
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(user)
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  isPlaceholder Boolean   @default(false)
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Ronin Dojo: which brand this user is currently working in
  // (drives `where: { brand }` scoping; persists across sessions)
  lastActiveBrandId Brand?

  // Relations (Dirstarter template)
  accounts  Account[]
  sessions  Session[]
  tools     Tool[]
  bookmarks Bookmark[]

  // Relations (Ronin Dojo)
  // @changed SESSION_0392 (Phase 3c) — identity satellites (directoryProfile, lineageNode,
  // affiliations, rankAwards earner, fightRecords) re-rooted onto Passport (SOT-ADR D1); their
  // User back-relations were dropped. `awardedRankAwards` stays — the promoter is an account actor.
  passport                   Passport?
  memberships                Membership[]
  awardedRankAwards          RankAward[]                 @relation("AwardedBy")
  ownedOrganizations         Organization[]              @relation("OrganizationOwner")
  lineageTreeAccessGrants    LineageTreeAccess[]         @relation("LineageTreeAccessUser")
  lineageTreeAccessGranted   LineageTreeAccess[]         @relation("LineageTreeAccessGrantedBy")
  lineageClaimRequests       LineageClaimRequest[]       @relation("LineageClaimClaimant")
  reviewedLineageClaims      LineageClaimRequest[]       @relation("LineageClaimReviewer")
  consumedPendingClaims      LineagePendingClaim[]       @relation("LineagePendingClaimConsumer")
  profileClaimRequests       ProfileClaimRequest[]       @relation("ProfileClaimClaimant")
  reviewedProfileClaims      ProfileClaimRequest[]       @relation("ProfileClaimReviewer")
  passportClaimRequests      PassportClaimRequest[]      @relation("PassportClaimClaimant")
  reviewedPassportClaims     PassportClaimRequest[]      @relation("PassportClaimReviewer")
  permissionGrants           UserPermissionGrant[]       @relation("UserPermissionGrantUser")
  permissionGrantsGranted    UserPermissionGrant[]       @relation("UserPermissionGrantGrantedBy")
  gamificationLog            GamificationEvent[]
  registrations              Registration[]
  subscriptions              UserBrandSubscription[]
  courseEnrollments          CourseEnrollment[]
  waiverSignatures           WaiverSignature[]
  waiverSignaturesOnBehalf   WaiverSignature[]           @relation("SignedOnBehalf")
  tournamentStaffAssignments TournamentStaffAssignment[]
  certifications             Certification[]
  issuedCertifications       Certification[]             @relation("CertIssuedBy")
  createdStyles              Style[]                     @relation("StyleCreatedBy")
  approvedStyles             Style[]                     @relation("StyleApprovedBy")
  verifiedItemCompletions    CurriculumItemCompletion[]  @relation("ItemVerifiedBy")
  createdContentAtoms        ContentAtom[]               @relation("AtomCreatedBy")
  assignedContentTasks       ContentTask[]               @relation("TaskAssignee")
  programEnrollments         ProgramEnrollment[]
  classInstructorAssignments ClassInstructorAssignment[]
  substituteClassSessions    ClassSession[]              @relation("ClassSessionSubstituteInstructor")
  attendances                Attendance[]
  checkIns                   CheckIn[]
  beltTestRegistrations      BeltTestRegistration[]
  familyMemberships          FamilyMember[]
  invoices                   Invoice[]
  contracts                  MembershipContract[]
  notificationPreferences    NotificationPreference[]
  payoutSplits               PayoutSplit[]
  stripeCustomers            StripeCustomer[]

  // Wave B relations
  createdInvites     Invite[]            @relation("InviteCreatedBy")
  inviteClaims       InviteClaim[]
  eventRegistrations EventRegistration[]
  auditLogs          AuditLog[]

  // Wave C relations
  leadFollowUps  LeadFollowUp[]  @relation("FollowUpAssignee")
  weighInRecords WeighInRecord[]

  // Wave D relations
  uploadedMedia          Media[]               @relation("MediaUploadedBy")
  favorites              Favorite[]
  studentListMemberships StudentListMember[]
  createdStudentLists    StudentList[]         @relation("ListCreatedBy")
  techniqueProgress      TechniqueProgress[]
  verifiedTechProgress   TechniqueProgress[]   @relation("TechProgressVerifiedBy")
  certificateOrders      CertificateOrder[]
  certificateIssuances   CertificateIssuance[]

  // Entitlement layer
  entitlements UserEntitlement[]

  // Merch / POD
  merchOrders MerchOrder[]

  // Blog
  posts Post[]

  // Community feed (SESSION_0493)
  communityPosts CommunityPost[]

  // GDPR / privacy
  dataSubjectRequests          DataSubjectRequest[] @relation("DataSubjectRequestSubmitter")
  dataSubjectRequestsFulfilled DataSubjectRequest[] @relation("DataSubjectRequestFulfiller")

  // Indexes
  @@index([id])
}

model Session {
  id             String   @id @default(cuid(2))
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid(2))
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Indexes
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid(2))
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Ad {
  id          String   @id @default(cuid(2))
  email       String
  name        String
  description String?
  websiteUrl  String
  faviconUrl  String?
  bannerUrl   String?
  buttonLabel String?
  type        AdType   @default(All)
  startsAt    DateTime
  endsAt      DateTime
  sessionId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tool {
  id             String     @id @default(cuid(2))
  name           String     @db.Citext
  slug           String     @unique
  websiteUrl     String
  affiliateUrl   String?
  tagline        String?
  description    String?
  content        String?
  faviconUrl     String?
  screenshotUrl  String?
  isFeatured     Boolean    @default(false)
  tier           ToolTier   @default(Free)
  tierPriority   Int        @default(dbgenerated())
  submitterName  String?
  submitterEmail String?
  submitterNote  String?
  status         ToolStatus @default(Draft)
  publishedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // Relations
  categories   Category[]
  tags         Tag[]
  reports      Report[]
  bookmarks    Bookmark[]
  owner        User?         @relation(fields: [ownerId], references: [id])
  ownerId      String?
  posts        Post[]
  contentAtoms ContentAtom[]

  @@index([id, slug])
  @@index([name])
  @@index([status])
  @@index([ownerId])
  @@index([tierPriority, publishedAt])
  @@index([createdAt])
}

model Category {
  id          String   @id @default(cuid(2))
  name        String   @db.Citext
  slug        String   @unique
  label       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Implicit relation
  tools Tool[]

  // @added SESSION_0396 — shared listing taxonomy across the directory entities (Tool→Listing parity).
  techniques    Technique[]
  organizations Organization[]
  passports     Passport[]
  posts         Post[]

  // Indexes
  @@index([slug])
}

model Tag {
  id        String   @id @default(cuid(2))
  name      String   @db.Citext
  slug      String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  // Relations
  tools        Tool[]
  contentAtoms ContentAtom[]

  // @added SESSION_0396 — shared listing taxonomy across the directory entities (Tool→Listing parity).
  techniques    Technique[]
  organizations Organization[]
  passports     Passport[]
  posts         Post[]

  // Indexes
  @@index([name])
}

model Report {
  id        String     @id @default(cuid(2))
  type      ReportType @default(Other)
  message   String?
  email     String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  tool   Tool?   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId String?

  // Indexes
  @@index([toolId])
}

// @added SESSION_0397 — polymorphic Save subject (Tool→Listing parity, ADR 0028 follow-up).
// "Everything is a listing": a User can favorite a Tool, a person (Passport — the identity SoT
// that feeds DirectoryProfile + lineage + board, ADR 0025), an Organization (school), a Technique,
// a Post, or a whole LineageTree. Shape mirrors ProfileClaimRequest: a subjectType discriminator +
// nullable FKs, exactly one set, matching subjectType (enforced in the bookmark action, not the DB).
enum BookmarkSubjectType {
  TOOL
  PERSON
  ORGANIZATION
  TECHNIQUE
  POST
  TREE
  // @added SESSION_0493 — member community post (/posts), distinct from editorial POST (/blog).
  COMMUNITY_POST
}

model Bookmark {
  id          String              @id @default(cuid(2))
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  // @added SESSION_0397 — discriminator; existing rows backfilled to TOOL by the migration.
  subjectType BookmarkSubjectType @default(TOOL)

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Polymorphic subject — exactly one set, matching subjectType (enforced in the action).
  // @changed SESSION_0397 — toolId relaxed to optional so non-tool subjects can be saved.
  tool            Tool?          @relation(fields: [toolId], references: [id], onDelete: Cascade)
  toolId          String?
  passport        Passport?      @relation(fields: [passportId], references: [id], onDelete: Cascade)
  passportId      String?
  organization    Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String?
  technique       Technique?     @relation(fields: [techniqueId], references: [id], onDelete: Cascade)
  techniqueId     String?
  post            Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId          String?
  lineageTree     LineageTree?   @relation(fields: [lineageTreeId], references: [id], onDelete: Cascade)
  lineageTreeId   String?
  // @added SESSION_0493 — community feed post subject (subjectType=COMMUNITY_POST).
  communityPost   CommunityPost? @relation(fields: [communityPostId], references: [id], onDelete: Cascade)
  communityPostId String?

  // Indexes — one (userId, subject) unique per subject type, plus per-FK lookup indexes.
  @@unique([userId, toolId])
  @@unique([userId, passportId])
  @@unique([userId, organizationId])
  @@unique([userId, techniqueId])
  @@unique([userId, postId])
  @@unique([userId, lineageTreeId])
  @@unique([userId, communityPostId])
  @@index([userId])
  @@index([userId, subjectType])
  @@index([toolId])
  @@index([passportId])
  @@index([organizationId])
  @@index([techniqueId])
  @@index([postId])
  @@index([lineageTreeId])
  @@index([communityPostId])
}

