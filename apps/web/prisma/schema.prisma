// @added   SESSION_0111 (2026-05-11)
// @why     Track Printful POD merch orders from Stripe checkout through fulfillment
// @wired   server/web/merch/, app/api/webhooks/stripe/, app/(web)/merch/orders/
/// Merch order with Printful POD fulfillment tracking.
/// Created by the Stripe webhook merch_purchase handler.
/// @see docs/architecture/printful-pod-spec.md
model MerchOrder {
  id    String @id @default(cuid())
  brand Brand

  /// Stripe checkout session that created this order
  stripeCheckoutSessionId String  @unique
  stripePaymentIntentId   String?

  /// Printful integration
  printfulOrderId    Int? /// Printful's internal order ID
  printfulExternalId String? /// Our ID sent to Printful (= this record's id)
  fulfillmentStatus  FulfillmentStatus @default(PAID)

  /// Order details
  customerEmail String
  customerName  String?
  amountCents   Int     @default(0)
  shippingCents Int     @default(0)
  totalCents    Int     @default(0)
  currency      String  @default("USD") @db.Char(3)

  /// Line item snapshot (JSON — product name, size, color, qty, printfulVariantId)
  lineItems Json?

  /// Shipping address snapshot
  shippingName        String?
  shippingAddress1    String?
  shippingAddress2    String?
  shippingCity        String?
  shippingState       String?
  shippingPostalCode  String?
  shippingCountryCode String?

  /// Fulfillment tracking (populated by Printful webhook)
  trackingNumber String?
  trackingUrl    String?
  carrier        String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  /// Error handling
  failureReason String?

  /// Append-only audit trail for admin status overrides (JSON array)
  /// Each entry: { timestamp, adminUserId, oldStatus, newStatus, reason? }
  /// @see docs/sprints/SESSION_0121.md — TASK_02 (FINDING_02 remediation)
  statusHistory Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  /// Relations
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  pricingPlan    PricingPlan? @relation(fields: [pricingPlanId], references: [id])
  pricingPlanId  String?

  @@index([brand, organizationId])
  @@index([brand, customerEmail])
  @@index([brand, fulfillmentStatus])
  @@index([userId])
  @@index([fulfillmentStatus])
  @@index([createdAt])
}

model Post {
  id          String     @id @default(cuid())
  title       String     @db.Citext
  slug        String     @unique
  description String?
  content     String
  plainText   String     @default("")
  imageUrl    String?
  status      PostStatus @default(Draft)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Brand scoping (ADR 0004)
  brand Brand

  // Relations
  author   User   @relation(fields: [authorId], references: [id])
  authorId String
  tools    Tool[]

  @@index([brand, slug])
  @@index([authorId])
  @@index([publishedAt])
}

enum DataSubjectRequestType {
  EXPORT
  DELETE
  RECTIFY
}

enum DataSubjectRequestStatus {
  PENDING
  IN_PROGRESS
  FULFILLED
  REJECTED
}

/// GDPR-like Data Subject Request queue.
/// Submissions go to this queue with status=PENDING; admin processes manually.
/// See SESSION_0254 for the Plausible/GDPR mutual understanding that drove this.
model DataSubjectRequest {
  id          String                   @id @default(cuid())
  userId      String
  type        DataSubjectRequestType
  status      DataSubjectRequestStatus @default(PENDING)
  reason      String?
  submittedAt DateTime                 @default(now())
  fulfilledAt DateTime?
  fulfilledBy String?
  notes       String?

  user      User  @relation("DataSubjectRequestSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  fulfiller User? @relation("DataSubjectRequestFulfiller", fields: [fulfilledBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}
