  PUBLISHED
  HIDDEN
}

// @added   SESSION_0493 — member-generated community feed post (/posts), a SIBLING of the
// editorial `Post` (/blog) per ADR 0042 Amendment 1: staff writes /blog, members post /posts.
// No kind-union onto Post; engagement (votes/comments) lands here in later additive phases.
// Author identity = User FK; display name/avatar resolve via Passport at the read layer.
model CommunityPost {
  id       String              @id @default(cuid(2))
  type     CommunityPostType
  title    String              @db.Citext
  slug     String              @unique
  content  String
  videoUrl String?
  imageUrl String?
  status   CommunityPostStatus @default(PUBLISHED)

  // @added SESSION_0537 (FI-028b) — per-post READ freemium. Default false = grandfather (every
  // existing + new post is free & PUBLIC, incl. logged-out visitors); a premium post stays IN the
  // feed but a locked viewer gets a teaser (excerpt kept; content/videoUrl/imageUrl stripped
  // server-side, the no-leak invariant). No new index — the feed `where` is unchanged.
  isPremium Boolean @default(false)

  // createdAt is the feed sort key (no publishedAt — posts are live on create).
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Brand scoping (ADR 0004)
  brand Brand

  // Relations
  author   User    @relation(fields: [authorId], references: [id])
  authorId String
  style    Style?  @relation(fields: [styleId], references: [id])
  styleId  String?

  // Polymorphic Bookmark (Save). subjectType=COMMUNITY_POST.
  bookmarks Bookmark[]

  // Feed query: (brand, status, createdAt desc) + optional type filter.
  @@index([brand, status, createdAt(sort: Desc)])
  @@index([brand, status, type, createdAt(sort: Desc)])
  @@index([authorId])
  @@index([styleId])
}

// @added   migration 20260525 (2026-05-25)
// @why     Kind of GDPR-like data-subject request (export / delete / rectify)
// @wired   app/(web)/privacy/request/_actions.ts, server/admin/privacy/actions.ts
enum DataSubjectRequestType {
  EXPORT
  DELETE
  RECTIFY
}

// @added   migration 20260525 (2026-05-25)
// @why     Admin-processing state of a data-subject request (pending → in-progress → fulfilled/rejected)
// @wired   server/admin/privacy/queries.ts, app/app/privacy/requests/[id]/_components/dsr-status-actions.tsx
enum DataSubjectRequestStatus {
  PENDING
  IN_PROGRESS
  FULFILLED
  REJECTED
}

/// GDPR-like Data Subject Request queue.
/// Submissions go to this queue with status=PENDING; admin processes manually.
/// See SESSION_0254 for the Plausible/GDPR mutual understanding that drove this.
// @added   migration 20260525 (2026-05-25)
// @why     GDPR-like data-subject request queue (export/delete/rectify) for manual admin fulfilment
// @wired   app/(web)/privacy/request/_actions.ts, server/admin/privacy/actions.ts, server/admin/privacy/queries.ts, app/app/privacy/requests/page.tsx
model DataSubjectRequest {
  id          String                   @id @default(cuid(2))
  userId      String
  type        DataSubjectRequestType
  status      DataSubjectRequestStatus @default(PENDING)
  reason      String?
  submittedAt DateTime                 @default(now())
  fulfilledAt DateTime?
  fulfilledBy String?
  notes       String?

  user      User  @relation("DataSubjectRequestSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  fulfiller User? @relation("DataSubjectRequestFulfiller", fields: [fulfilledBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}

