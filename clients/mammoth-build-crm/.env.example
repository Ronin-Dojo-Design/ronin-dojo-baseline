# Mammoth Build CRM — its OWN database + identity (ADR 0038: one DB per product).
#
# Each product owns its own DATABASE_URL + auth secret; there is no shared DB and
# no cross-product foreign keys. Copy this file to `.env` (gitignored) for local dev.

# --- Database -----------------------------------------------------------------
# Local dev = Postgres.app. Omitting the user lets libpq default to your macOS
# username (trust auth). Set an explicit user if yours differs.
DATABASE_URL="postgresql://localhost:5432/mammoth_dev"

# Staging/prod (Neon) — set these on the Vercel project (operator-gated, TASK_03):
#   DATABASE_URL  = the POOLED connection string (…-pooler.…, ?pgbouncer=true) — the
#                   runtime client (lib/db.ts) uses this.
#   DIRECT_URL    = the DIRECT (non-pooled) string — Prisma Migrate uses this on
#                   deploy (prisma.config.ts normalizes the -pooler host away).
# DIRECT_URL="postgresql://USER:PASS@HOST.neon.tech/mammoth_staging?sslmode=require"

# --- Auth (Better Auth — per-product identity, ADR 0038 D5) -------------------
# Required. Generate a strong random secret (e.g. `openssl rand -base64 32`).
# NEVER commit a real value — set it in `.env` locally and on the Vercel project.
BETTER_AUTH_SECRET="generate-a-strong-random-secret"
# The canonical origin Better Auth signs/validates against. On Vercel previews it
# falls back to VERCEL_URL automatically; set the explicit staging URL in prod.
BETTER_AUTH_URL="http://localhost:3000"
